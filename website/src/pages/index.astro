---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getEntry, getCollection, getEntry as getEntryRef } from 'astro:content';
import siteConfig from '@/config/site.config';

type Screenshot = { src: string; alt: string; caption?: string };
type SingleMedia = Screenshot;
type SliderMedia = { slider: Screenshot[] };
type SectionMedia = SingleMedia | SliderMedia;

// Load the single landing entry. Validated against the Zod schema at build time,
// so every section below can trust the frontmatter shape.
const home = await getEntry('landing', 'home');
if (!home) {
  throw new Error('Missing landing content at src/content/landing/home.mdx');
}
const { hero, features, instance, sections, install } = home.data;

// Latest blog posts (up to 3, non-draft, newest first).
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = (
  await Promise.all(
    allPosts
      .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
      .slice(0, 3)
      .map(async (post) => {
        const authorEntry = await getEntryRef(post.data.author);
        return { post, authorName: authorEntry?.data.name ?? siteConfig.name };
      })
  )
);
---

<LandingLayout
  title={home.data.title}
  description={home.data.description}
  image={hero.screenshot.src}
  imageAlt={hero.screenshot.alt}
  includeOrgSchema={true}
>
  {/* ========================= Hero ========================= */}
  <Hero layout="centered" size="xl" class="hero-dark-gradient">
    {hero.eyebrow && (
      <Badge slot="badge" variant="brand" pill>{hero.eyebrow}</Badge>
    )}

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">{hero.heading}</span>
    </h1>

    <p slot="description">{hero.subheading}</p>

    <Fragment slot="actions">
      {hero.ctas.map((cta) => (
        <Button
          size="lg"
          href={cta.href}
          variant={cta.variant === 'secondary' ? 'outline' : undefined}
          target={cta.external ? '_blank' : undefined}
          rel={cta.external ? 'noopener noreferrer' : undefined}
        >
          {cta.label}
          {!cta.external && <Icon name="arrow-right" size="sm" />}
        </Button>
      ))}
    </Fragment>
  </Hero>

  {/* Screenshot */}
  <section class="relative z-10 -mt-16 pb-16">
    <div class="mx-auto max-w-5xl px-6">
      <img
        src={hero.screenshot.src}
        alt={hero.screenshot.alt}
        class="w-full rounded-xl border border-border shadow-2xl"
        loading="eager"
      />
    </div>
  </section>

  {/* ========================= Features grid ========================= */}
  <section id="features" class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Features</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          {features.heading}
        </h2>
        {features.subheading && (
          <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
            {features.subheading}
          </p>
        )}
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal data-reveal-delay="1">
        {features.items.map((item) => (
          <Card hover>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name={item.icon} size="sm" />
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-foreground">{item.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  {item.body}
                </p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  {/* ========================= What is an instance? ========================= */}
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-10">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Anatomy</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          {instance.heading}
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          {instance.body}
        </p>
      </div>

      <div class="grid gap-6 grid-cols-2 md:grid-cols-5" data-reveal data-reveal-delay="1">
        {instance.items.map((item) => (
          <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500">
            <Icon name={item.icon} class="w-10 h-10 text-brand-500" />
            <p class="text-sm font-semibold text-foreground">{item.title}</p>
            <p class="text-xs text-foreground-muted">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ========================= Split sections ========================= */}
  {sections.map((section, idx) => {
    const isAlt = section.background === 'alt';
    const mediaLeft = section.mediaSide === 'left';
    const media = section.media as SectionMedia;
    const isSlider = 'slider' in media;
    const sliderMedia = isSlider ? (media as SliderMedia).slider : [];
    const singleMedia = !isSlider ? (media as SingleMedia) : null;
    return (
      <section
        id={section.id}
        class:list={[
          'relative z-10 py-[var(--space-section-md)] border-t border-border',
          isAlt ? 'bg-background-secondary' : 'bg-background',
        ]}
      >
        <div class="mx-auto max-w-6xl px-6">
          <div class:list={['grid gap-12 lg:grid-cols-2 items-center', mediaLeft && 'lg:[&>div:first-child]:order-2']}>
            <div data-reveal>
              {section.eyebrow && (
                <Badge variant="brand" pill class="self-start mb-4">{section.eyebrow}</Badge>
              )}
              <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4">
                {section.title}
              </h2>
              <p class="text-lg text-foreground-muted leading-relaxed">{section.body}</p>
            </div>

            <div data-reveal data-reveal-delay="1">
              {isSlider ? (
                <div class="claworc-slider relative" data-slider>
                  {sliderMedia.map((s, i) => (
                    <img
                      src={s.src}
                      alt={s.alt}
                      class:list={[
                        'w-full rounded-xl border border-border shadow-lg transition-opacity duration-300',
                        i === 0 ? 'relative opacity-100' : 'absolute inset-0 opacity-0',
                      ]}
                      data-slide={i}
                      loading="lazy"
                    />
                  ))}
                  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 z-10">
                    {sliderMedia.map((_, i) => (
                      <button
                        type="button"
                        class:list={[
                          'h-2 w-2 rounded-full transition-colors',
                          i === 0 ? 'bg-brand-500' : 'bg-foreground-muted/40',
                        ]}
                        data-dot={i}
                        aria-label={`Show screenshot ${i + 1}`}
                      />
                    ))}
                  </div>
                </div>
              ) : singleMedia && (
                <img
                  src={singleMedia.src}
                  alt={singleMedia.alt}
                  class="w-full rounded-xl border border-border shadow-lg"
                  loading="lazy"
                />
              )}
            </div>
          </div>
        </div>
      </section>
    );
  })}

  {/* ========================= Install ========================= */}
  <section id="install" class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-10">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Install</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          {install.heading}
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          {install.subheading}
        </p>
      </div>

      <div class="mx-auto w-full max-w-3xl" data-reveal data-reveal-delay="1">
        <div class="rounded-xl border border-border bg-background-tertiary p-4 font-mono text-sm flex items-center justify-between gap-4">
          <code class="truncate text-foreground">{install.command}</code>
          <Button
            size="sm"
            variant="outline"
            href={install.commandHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            Docs
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="2">
        {install.tiles.map((tile) => (
          <Card hover href={tile.href}>
            <div class="flex flex-col gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name={tile.icon} size="sm" />
              </div>
              <h3 class="text-base font-semibold text-foreground">{tile.title}</h3>
              <p class="text-sm text-foreground-muted leading-relaxed">{tile.body}</p>
              <span class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500">
                {tile.cta}
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  {/* ========================= Latest blog posts ========================= */}
  {recentPosts.length > 0 && (
    <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
        <div class="flex items-end justify-between" data-reveal>
          <div class="flex flex-col gap-3">
            <Badge variant="brand" pill class="self-start">From the blog</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Latest posts
            </h2>
          </div>
          <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
            All posts
            <Icon name="arrow-right" size="sm" />
          </a>
        </div>

        <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
          {recentPosts.map(({ post, authorName }) => (
            <Card hover href={`/blog/${post.id}`}>
              <div class="flex flex-col gap-3 h-full">
                <h3 class="text-base font-semibold text-foreground">{post.data.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed flex-1">{post.data.description}</p>
                <div class="flex items-center justify-between text-xs text-foreground-muted">
                  <span>{authorName}</span>
                  <time datetime={post.data.publishedAt.toISOString()}>
                    {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                </div>
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}
</LandingLayout>

<script>
  // Lightweight slider: clicking dots cross-fades images within each .claworc-slider.
  function initSliders() {
    const sliders = document.querySelectorAll<HTMLElement>('.claworc-slider[data-slider]');
    sliders.forEach((slider) => {
      if (slider.dataset.sliderInit) return;
      slider.dataset.sliderInit = 'true';

      const slides = slider.querySelectorAll<HTMLElement>('[data-slide]');
      const dots = slider.querySelectorAll<HTMLElement>('[data-dot]');

      function show(i: number) {
        slides.forEach((s, idx) => {
          const first = idx === 0;
          s.classList.toggle('opacity-100', idx === i);
          s.classList.toggle('opacity-0', idx !== i);
          s.classList.toggle('relative', idx === i);
          s.classList.toggle('absolute', idx !== i);
          s.classList.toggle('inset-0', idx !== i);
          if (first && idx !== i) {
            s.classList.add('absolute', 'inset-0');
            s.classList.remove('relative');
          }
        });
        dots.forEach((d, idx) => {
          d.classList.toggle('bg-brand-500', idx === i);
          d.classList.toggle('bg-foreground-muted/40', idx !== i);
        });
      }

      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => show(idx));
      });
    });
  }

  initSliders();
  document.addEventListener('astro:page-load', initSliders);
  document.addEventListener('astro:after-swap', initSliders);
</script>
