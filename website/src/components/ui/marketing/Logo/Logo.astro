---
/**
 * Logo Component
 *
 * Renders the Claworc wordmark SVG from /public/images/logo.svg as an <img>.
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  /** Size preset — controls height; width is auto to preserve aspect ratio */
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Force dark mode logo — no-op, kept for API compat */
  forceDark?: boolean;
  /** Use full logo instead of logomark — no-op, kept for API compat */
  variant?: 'logomark' | 'full';
  /** Additional CSS classes */
  class?: string;
  /** Override letter — no-op, kept for API compat with the previous monogram logo */
  letter?: string;
}

const { size = 'md', class: className } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'h-5 w-auto',
  md: 'h-7 w-auto',
  lg: 'h-9 w-auto',
  xl: 'h-12 w-auto',
  '2xl': 'h-24 w-auto',
};

const boxClass = sizeClasses[size] ?? sizeClasses.md;
---

<img
  src="/images/logo.svg"
  alt={siteConfig.branding.logo.alt}
  class={cn('shrink-0 select-none', boxClass, className)}
  loading="eager"
  decoding="async"
/>
