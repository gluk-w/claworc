---
/**
 * Starlight Header override — renders the marketing Header with the
 * same props the landing page uses (LandingLayout.astro), so the docs
 * top bar is visually identical to the home page.
 */
import MarketingHeader from '@/components/layout/Header.astro';
---

<MarketingHeader
  position="fixed"
  shape="floating"
  variant="default"
  colorScheme="default"
  size="lg"
  showCta={false}
  showThemeSelector={false}
/>
