---
/**
 * Custom Starlight PageFrame that renders the marketing <Header /> and
 * <Footer /> at the document root — OUTSIDE Starlight's .page wrapper and
 * its nested <header class="header">. Rendering the fixed floating pill
 * inside another position:fixed ancestor established a containing block
 * that mis-sized `left: 50%` and clipped the pill, so we skip the wrapper
 * entirely.
 *
 * Starlight's Header slot is still declared (filled by our override in
 * src/components/docs/Header.astro) but is placed at the body root, where
 * the pill's `position: fixed` resolves against the viewport exactly like
 * on /blog and /.
 */
import MobileMenuToggle from 'virtual:starlight/components/MobileMenuToggle';
import MarketingFooter from '@/components/layout/Footer.astro';

const { hasSidebar } = Astro.locals.starlightRoute;
---

<slot name="header" />

<div class="page sl-flex">
  {
    hasSidebar && (
      <nav class="sidebar print:hidden" aria-label={Astro.locals.t('sidebarNav.accessibleLabel')}>
        <MobileMenuToggle />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
</div>

<MarketingFooter />

<script is:inline>
  // Keep the fixed sidebar from overlapping the footer: measure how far the
  // footer has scrolled into the viewport and push the sidebar's bottom up
  // by the same amount.
  (function () {
    function init() {
      var sidebar = document.querySelector('.sidebar-pane');
      var footer = document.querySelector('body > footer');
      if (!sidebar || !footer) return;
      function update() {
        var rect = footer.getBoundingClientRect();
        var overlap = Math.max(0, window.innerHeight - rect.top);
        sidebar.style.bottom = overlap + 'px';
      }
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  @layer starlight.core {
    .page {
      flex-direction: column;
      min-height: 100vh;
    }

    .header {
      z-index: var(--sl-z-index-navbar);
      position: fixed;
      inset-inline-start: 0;
      inset-block-start: 0;
      width: 100%;
      height: var(--sl-nav-height);
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      padding-inline-end: var(--sl-nav-pad-x);
      background-color: var(--sl-color-bg-nav);
    }

    :global([data-has-sidebar]) .header {
      padding-inline-end: calc(
        var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size)
      );
    }

    .sidebar-pane {
      visibility: var(--sl-sidebar-visibility, hidden);
      position: fixed;
      z-index: var(--sl-z-index-menu);
      inset-block: var(--sl-nav-height) 0;
      inset-inline-start: 0;
      width: 100%;
      background-color: var(--sl-color-black);
      overflow-y: auto;
    }

    :global([aria-expanded='true']) ~ .sidebar-pane {
      --sl-sidebar-visibility: visible;
    }

    .sidebar-content {
      height: 100%;
      min-height: max-content;
      padding: 1rem var(--sl-sidebar-pad-x) 0;
      flex-direction: column;
      gap: 1rem;
    }

    @media (min-width: 50rem) {
      .sidebar-content::after {
        content: '';
        padding-bottom: 1px;
      }
    }

    .main-frame {
      padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height));
      padding-inline-start: var(--sl-content-inline-start);
    }

    @media (min-width: 50rem) {
      :global([data-has-sidebar]) .header {
        padding-inline-end: var(--sl-nav-pad-x);
      }
      .sidebar-pane {
        --sl-sidebar-visibility: visible;
        width: var(--sl-sidebar-width);
        background-color: var(--sl-color-bg-sidebar);
        border-inline-end: 1px solid var(--sl-color-hairline-shade);
      }
    }
  }
</style>
